{
  "name": "localclaw",
  "version": "0.1.0",
  "description": "Nanoclaw clone using local Ollama + OpenCode agents",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx --env-file=.env src/index.ts",
    "build": "npm run build:server && npm run build:client",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "build:server": "tsc",
    "build:client": "npm --prefix client run build",
    "start": "node dist/index.js",
    "setup:opencode": "node scripts/setup-opencode.js"
  },
  "dependencies": {
    "better-sqlite3": "^11.0.0",
    "chalk": "^5.3.0",
    "cors": "^2.8.5",
    "express": "^4.21.0",
    "multer": "^2.1.1",
    "playwright": "^1.60.0",
    "puppeteer-core": "^25.0.2",
    "ws": "^8.20.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.8",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/multer": "^2.1.0",
    "@types/node": "^22.0.0",
    "@types/ws": "^8.18.1",
    "tsx": "^4.16.0",
    "typescript": "^5.5.0",
    "vitest": "^4.1.6"
  }
}
