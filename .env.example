# ───── localclaw configuration ─────
# Copy this file to .env and fill in your values.
# cp .env.example .env

# Server port
# LOCALCLAW_PORT=4173

# Data directory (sessions, messages, tools, downloads)
# LOCALCLAW_DATA_DIR=~/.localclaw

# Ollama API URL
# LOCALCLAW_OLLAMA_URL=http://localhost:11434

# Default model for new sessions
# LOCALCLAW_MODEL=ollama/qwen2.5:3b

# SearXNG search engine URL (optional — falls back to DuckDuckGo if empty)
# LOCALCLAW_SEARXNG_URL=http://localhost:8888

# API key for REST API authentication (optional)
# When set, all API requests (except /api/health) require a Bearer token:
#   Authorization: Bearer <LOCALCLAW_API_KEY>
# LOCALCLAW_API_KEY=

# OpenCode binary path
# LOCALCLAW_OPENCODE_BIN=opencode

# Sandbox: wrap code execution in Docker containers (true/false)
# LOCALCLAW_SANDBOX_ENABLED=false

# Sandbox Docker image to use
# LOCALCLAW_SANDBOX_IMAGE=ubuntu:22.04

# Embedding model for RAG memory (must be pulled in Ollama)
# LOCALCLAW_EMBEDDING_MODEL=nomic-embed-text

# Log level: debug, info, warn, error
# LOCALCLAW_LOG_LEVEL=info

# ───── HTTPS (optional) ─────
# Paths to TLS certificate and key files. Both must exist to enable HTTPS.
# LOCALCLAW_HTTPS_KEY=/path/to/privkey.pem
# LOCALCLAW_HTTPS_CERT=/path/to/cert.pem

# ───── Mailgun email delivery (optional) ─────
# See https://documentation.mailgun.com/
# LOCALCLAW_MAILGUN_API_KEY=
# LOCALCLAW_MAILGUN_DOMAIN=
# LOCALCLAW_MAILGUN_FROM=localclaw <mailgun@your-domain.mailgun.org>

# ───── Telegram bot (optional) ─────
# See https://core.telegram.org/bots
# LOCALCLAW_TELEGRAM_BOT_TOKEN=
# LOCALCLAW_TELEGRAM_CHAT_ID=

# ───── OpenCode (optional) ─────
# API key enables cloud models (Anthropic Claude) in delegated tasks.
# LOCALCLAW_OPENCODE_API_KEY=
